{
  "name": "@loop-engine/adapter-pagerduty",
  "version": "0.1.4",
  "description": "Route Loop Engine approval-required states to PagerDuty incidents",
  "keywords": [
    "loop-engine",
    "workflow",
    "governance",
    "state-machine",
    "audit-trail",
    "actors",
    "guards",
    "enterprise",
    "supply-chain",
    "decision-governance",
    "pagerduty",
    "incident",
    "alerting",
    "oncall"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/loopengine/loop-engine",
    "directory": "packages/adapter-pagerduty"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@loop-engine/core": "0.1.4"
  },
  "peerDependencies": {
    "@loop-engine/core": "0.1.4"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
