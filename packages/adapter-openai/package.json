{
  "name": "@loop-engine/adapter-openai",
  "version": "0.1.6",
  "description": "OpenAI adapter for governed GPT loop actors.",
  "keywords": [
    "loop-engine",
    "ai-adapter",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "openai",
    "gpt-4o",
    "llm"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/adapter-openai"
  },
  "homepage": "https://loopengine.io/docs/packages/adapter-openai",
  "bugs": {
    "url": "https://github.com/loopengine/loop-engine/issues"
  },
  "author": "Better Data, Inc. (https://betterdata.co)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/actors": "workspace:*",
    "@loop-engine/core": "workspace:*",
    "openai": "^6.4.1"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
