{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.base.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "@loop-engine/observability#build": {
      "dependsOn": [
        "^build",
        "@loop-engine/core#build",
        "@loop-engine/runtime#build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "@loop-engine/runtime#build": {
      "dependsOn": [
        "^build",
        "@loop-engine/actors#build",
        "@loop-engine/core#build",
        "@loop-engine/dsl#build",
        "@loop-engine/events#build",
        "@loop-engine/guards#build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "@loop-engine/sdk#build": {
      "dependsOn": [
        "^build",
        "@loop-engine/adapter-memory#build",
        "@loop-engine/core#build",
        "@loop-engine/dsl#build",
        "@loop-engine/events#build",
        "@loop-engine/guards#build",
        "@loop-engine/observability#build",
        "@loop-engine/registry-client#build",
        "@loop-engine/runtime#build",
        "@loop-engine/signals#build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
