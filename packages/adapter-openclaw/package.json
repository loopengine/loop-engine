{
  "name": "@loop-engine/adapter-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw gateway EventBus adapter for Loop Engine",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@loop-engine/events": "workspace:*",
    "@loop-engine/runtime": "workspace:*"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "ws": "^8.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
