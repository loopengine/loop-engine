{
  "name": "@loop-engine/runtime",
  "version": "1.0.0-rc.0",
  "description": "Execution engine for loop state transitions and lifecycle.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/runtime"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/actors": "workspace:*",
    "@loop-engine/core": "workspace:*",
    "@loop-engine/guards": "workspace:*"
  },
  "peerDependencies": {
    "@loop-engine/events": "workspace:^"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "homepage": "https://loopengine.io/docs/packages/runtime",
  "keywords": [
    "loop-engine",
    "core",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "execution",
    "lifecycle",
    "engine"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false
}
