# RT-20b — Loop Engine self-host compose env.
# Copy to deploy/compose/.env.compose and edit values. All have sane defaults
# baked into docker-compose.yml so this file is optional for first boot.

# --- Port overrides (optional) ---
SELF_HOST_POSTGRES_PORT=5435
SELF_HOST_REGISTRY_PORT=3011
SELF_HOST_RUNTIME_PORT=3012
SELF_HOST_STUDIO_PORT=3020

# --- Auth ---
# Registry publisher Bearer (write APIs only — GETs are public).
PUBLISHER_TOKEN_SECRET=self-host-publisher-token

# OSS runtime auth mode. "db" = validate against @loop-engine/runtime-db's
# LoopEngineApiKey table (default; honors the seed script). "memory" =
# accept LOOP_ENGINE_DEMO_API_KEY without DB lookup (useful when iterating
# on the runtime before the DB is migrated).
LOOP_ENGINE_AUTH_MODE=db
LOOP_ENGINE_DEFAULT_TENANT_ID=self-host-tenant

# Studio HTTP-mode API key. Seeded by scripts/self-host/seed-demo-run.ts.
# Must match the API key the seed script creates.
LOOP_ENGINE_API_KEY=le_5e1f0057de51f057de51f057de51f001
