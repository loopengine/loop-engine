{
  "name": "@loop-engine/adapter-perplexity",
  "version": "0.1.0",
  "description": "Perplexity Sonar API adapter for Loop Engine multi-LLM steps (grounded search + reasoning).",
  "keywords": [
    "loop-engine",
    "ai-adapter",
    "perplexity",
    "sonar",
    "llm",
    "ai-governance",
    "human-in-the-loop"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/adapter-perplexity"
  },
  "homepage": "https://loopengine.io/docs/packages/adapter-perplexity",
  "bugs": {
    "url": "https://github.com/loopengine/loop-engine/issues"
  },
  "author": "Better Data, Inc. (https://betterdata.co)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
