{
  "name": "@loop-engine/core",
  "version": "1.0.0-rc.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/core"
  },
  "description": "Canonical loop types, contracts, and model primitives.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "homepage": "https://loopengine.io/docs/packages/core",
  "sideEffects": false,
  "keywords": [
    "loop-engine",
    "core",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "types",
    "contracts",
    "model"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
