{
  "name": "@loop-engine/ui-devtools",
  "version": "0.1.0",
  "description": "React devtools components for inspecting Loop Engine state, events, and metrics",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment jsdom"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/observability": "workspace:*",
    "@loop-engine/events": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "jsdom": "^26.1.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
