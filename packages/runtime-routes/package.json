{
  "name": "@loop-engine/runtime-routes",
  "version": "1.0.0-rc.1",
  "private": false,
  "description": "Route handler factories for the RT-01 frozen Loop Engine runtime API. Mounted by the OSS self-host app (`apps/loop-engine-runtime`).",
  "keywords": [
    "loop-engine",
    "self-host",
    "runtime",
    "next",
    "oss"
  ],
  "license": "Apache-2.0",
  "author": "Better Data, Inc.",
  "homepage": "https://loopengine.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/betterdataco/bd-forge-main.git",
    "directory": "packages/oss/loop-engine-runtime-routes"
  },
  "bugs": {
    "url": "https://github.com/betterdataco/bd-forge-main/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/auth-iface": "workspace:*",
    "@loop-engine/entitlements-iface": "workspace:*",
    "@loop-engine/observability": "workspace:*",
    "@loop-engine/runtime-core": "workspace:*"
  },
  "peerDependencies": {
    "@loop-engine/runtime": "workspace:*"
  },
  "devDependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/runtime": "workspace:*",
    "@types/node": "^20.14.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
