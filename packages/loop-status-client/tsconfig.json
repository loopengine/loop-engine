{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "isolatedModules": true,
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/__tests__"]
}
