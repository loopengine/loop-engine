{
  "name": "@loop-engine/adapter-kafka",
  "version": "0.1.6",
  "description": "Kafka-backed loop persistence and event streaming adapter.",
  "homepage": "https://loopengine.io/docs/packages/adapter-kafka",
  "keywords": [
    "loop-engine",
    "store",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "kafka",
    "streaming",
    "queue"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/adapters/kafka"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@loop-engine/events": "workspace:*",
    "@loop-engine/runtime": "workspace:*"
  },
  "peerDependencies": {
    "kafkajs": "^2.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
