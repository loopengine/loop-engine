    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@loop-engine/core": "^0.1.5"
  },
  "devDependencies": {
    "@loop-engine/core": "workspace:*",
    "msw": "^2.7.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "files": [
    "dist/",
    "README.md",
    "BOUNDARY-MANAGEMENT.md",
    "LICENSE"
