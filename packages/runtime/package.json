{
  "name": "@loop-engine/runtime",
  "version": "0.1.0",
  "description": "Loop Engine runtime for state transitions, guard evaluation, and event emission",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/dsl": "workspace:*",
    "@loop-engine/events": "workspace:*",
    "@loop-engine/actors": "workspace:*",
    "@loop-engine/guards": "workspace:*"
  },
  "peerDependencies": {
    "@loop-engine/events": "workspace:*"
  },
  "devDependencies": {},
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
