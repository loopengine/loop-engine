{
  "name": "@loop-engine/sdk",
  "version": "0.1.4",
  "description": "Primary Loop Engine entrypoint combining runtime, DSL, guards, signals, and adapters",
  "keywords": [
    "loop-engine",
    "workflow",
    "governance",
    "state-machine",
    "audit-trail",
    "actors",
    "guards",
    "enterprise",
    "supply-chain",
    "decision-governance",
    "sdk",
    "typescript"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/loopengine/loop-engine",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "0.1.4",
    "@loop-engine/runtime": "0.1.4",
    "@loop-engine/dsl": "0.1.4",
    "@loop-engine/guards": "0.1.4",
    "@loop-engine/signals": "0.1.4",
    "@loop-engine/events": "0.1.4",
    "@loop-engine/observability": "0.1.4",
    "@loop-engine/adapter-memory": "0.1.4",
    "@loop-engine/registry-client": "0.1.4"
  },
  "devDependencies": {},
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
