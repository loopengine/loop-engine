{
  "name": "@loop-engine/sdk",
  "version": "0.1.0",
  "description": "Primary Loop Engine entrypoint combining runtime, DSL, guards, signals, and adapters",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/runtime": "workspace:*",
    "@loop-engine/dsl": "workspace:*",
    "@loop-engine/guards": "workspace:*",
    "@loop-engine/signals": "workspace:*",
    "@loop-engine/events": "workspace:*",
    "@loop-engine/observability": "workspace:*",
    "@loop-engine/adapter-memory": "workspace:*",
    "@loop-engine/registry-client": "workspace:*"
  },
  "devDependencies": {},
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
