{
  "name": "@loop-engine/sdk",
  "version": "0.1.7",
  "description": "Entry point for building and running governed loops.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/adapter-memory": "workspace:*",
    "@loop-engine/core": "workspace:*",
    "@loop-engine/dsl": "workspace:*",
    "@loop-engine/events": "workspace:*",
    "@loop-engine/guards": "workspace:*",
    "@loop-engine/observability": "workspace:*",
    "@loop-engine/registry-client": "workspace:*",
    "@loop-engine/runtime": "workspace:*",
    "@loop-engine/signals": "workspace:*"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://loopengine.io/docs/packages/sdk",
  "keywords": [
    "loop-engine",
    "core",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "entry-point",
    "builder"
  ]
}
