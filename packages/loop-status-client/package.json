{
  "name": "@loop-engine/loop-status-client",
  "version": "0.1.0",
  "description": "OSS client for the Boss Loops Cloud loop-status API: subscribe (SSE) + cursor pull/replay over OSS LoopEvent types.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/loop-status-client"
  },
  "homepage": "https://loopengine.io/docs/packages/loop-status-client",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/events": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "loop-engine",
    "loop-status",
    "sse",
    "event-stream",
    "cursor-replay",
    "client"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
