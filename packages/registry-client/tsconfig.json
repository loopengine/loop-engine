{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "isolatedModules": true,
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts", "betterdata.ts"],
  "exclude": ["src/__tests__", "src/**/*.test.ts", "examples"]
}
