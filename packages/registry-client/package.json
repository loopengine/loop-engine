{
  "name": "@loop-engine/registry-client",
  "version": "0.1.5",
  "description": "Loop definition registry adapters for local, HTTP, and Better Data registry sources",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/loopengine/loop-engine",
    "directory": "packages/registry-client"
  },
  "keywords": [
    "loop-engine",
    "workflow",
    "governance",
    "state-machine",
    "audit-trail",
    "actors",
    "guards",
    "enterprise",
    "supply-chain",
    "decision-governance",
    "registry",
    "loop-registry",
    "client"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./betterdata": {
      "import": "./dist/betterdata.js",
      "require": "./dist/betterdata.cjs",
      "types": "./dist/betterdata.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "0.1.5",
    "@loop-engine/dsl": "0.1.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "express": "^4.22.1"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
