{
  "name": "@loop-engine/observability",
  "version": "1.0.0-rc.1",
  "private": false,
  "description": "Trace store contract, metrics, and timelines for Loop Engine",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/observability"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:contract": "vitest run src/__tests__/trace-exports.test.ts"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*"
  },
  "devDependencies": {
    "@loop-engine/runtime": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
