{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@loopengine/core": ["packages/core/src/index.ts"],
      "@loopengine/dsl": ["packages/dsl/src/index.ts"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
