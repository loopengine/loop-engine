{
  "name": "@loop-engine/registry-client",
  "version": "1.0.0-rc.1",
  "private": false,
  "description": "Registry discovery client for loop definition catalogs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/registry-client"
  },
  "keywords": [
    "loop-engine",
    "observability",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "registry",
    "discovery",
    "catalog"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./betterdata": {
      "import": "./dist/betterdata.js",
      "require": "./dist/betterdata.cjs",
      "types": "./dist/betterdata.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:contract": "vitest run src/__tests__/registry-loop-v0-contract.test.ts src/__tests__/v0.test.ts"
  },
  "dependencies": {
    "@loop-engine/core": "1.0.0-rc.0",
    "@loop-engine/loop-definition": "1.0.0-rc.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "express": "^4.22.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "homepage": "https://loopengine.io/docs/packages/registry-client",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
