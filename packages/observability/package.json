{
  "name": "@loop-engine/observability",
  "version": "0.1.6",
  "description": "Metrics, timelines, and audit telemetry for loop execution.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/observability"
  },
  "keywords": [
    "loop-engine",
    "observability",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "metrics",
    "timeline",
    "audit"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/runtime": "workspace:*"
  },
  "devDependencies": {},
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "homepage": "https://loopengine.io/docs/packages/observability",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
