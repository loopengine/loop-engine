{
  "name": "@loop-engine/runtime",
  "version": "0.1.5",
  "description": "Loop Engine runtime for state transitions, guard evaluation, and event emission",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/loopengine/loop-engine",
    "directory": "packages/runtime"
  },
  "keywords": [
    "loop-engine",
    "workflow",
    "governance",
    "state-machine",
    "audit-trail",
    "actors",
    "guards",
    "enterprise",
    "supply-chain",
    "decision-governance",
    "runtime",
    "execution",
    "lifecycle",
    "transitions"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/dsl": "workspace:*",
    "@loop-engine/events": "workspace:*",
    "@loop-engine/actors": "workspace:*",
    "@loop-engine/guards": "workspace:*"
  },
  "peerDependencies": {
    "@loop-engine/events": "workspace:*"
  },
  "devDependencies": {},
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
