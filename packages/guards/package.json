{
  "name": "@loop-engine/guards",
  "version": "0.1.2",
  "description": "Deterministic policy guard registry and built-in guard evaluators",
  "license": "Apache-2.0",
  "keywords": [
    "loop-engine",
    "workflow",
    "governance",
    "state-machine",
    "audit-trail",
    "actors",
    "guards",
    "enterprise",
    "supply-chain",
    "decision-governance",
    "policy",
    "enforcement",
    "confidence-threshold"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
