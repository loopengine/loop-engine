{
  "name": "@loop-engine/adapter-openai",
  "version": "0.1.4",
  "description": "OpenAI adapter for creating Loop Engine AI actor submissions",
  "keywords": [
    "loop-engine",
    "workflow",
    "governance",
    "state-machine",
    "audit-trail",
    "actors",
    "guards",
    "enterprise",
    "supply-chain",
    "decision-governance",
    "openai",
    "gpt",
    "gpt-4o",
    "ai",
    "llm"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/loopengine/loop-engine",
    "directory": "packages/adapter-openai"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/actors": "0.1.4",
    "@loop-engine/core": "0.1.4",
    "openai": "^6.4.1"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
