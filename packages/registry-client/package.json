{
  "name": "@loop-engine/registry-client",
  "version": "0.1.5",
  "description": "Registry discovery client for loop definition catalogs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/registry-client"
  },
  "keywords": [
    "loop-engine",
    "observability",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "registry",
    "discovery",
    "catalog"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
