{
  "name": "@loop-engine/ui-devtools",
  "version": "0.1.6",
  "description": "Devtools and replay UI for debugging governed loops.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/ui-devtools"
  },
  "keywords": [
    "loop-engine",
    "observability",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "devtools",
    "debug",
    "replay"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment jsdom"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/events": "workspace:*",
    "@loop-engine/observability": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "jsdom": "^26.1.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://loopengine.io/docs/packages/devtools",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
