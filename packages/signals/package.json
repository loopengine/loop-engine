{
  "name": "@loop-engine/signals",
  "version": "1.0.0-rc.0",
  "description": "Signal primitives for feedback and training loops.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/signals"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "zod": "^3.22.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "homepage": "https://loopengine.io/docs/packages/signals",
  "sideEffects": false,
  "keywords": [
    "loop-engine",
    "core",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "signal",
    "feedback",
    "training"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
