{
  "name": "@loop-engine/adapter-memory",
  "version": "0.1.5",
  "description": "In-memory loop state store for local development.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/adapter-memory"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "@loop-engine/runtime": "workspace:*"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://loopengine.io/docs/packages/adapter-memory",
  "sideEffects": false,
  "keywords": [
    "loop-engine",
    "store",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "memory",
    "in-memory",
    "dev"
  ]
}
