{
  "name": "@loop-engine/loop-definition",
  "version": "1.0.0-rc.0",
  "description": "YAML parse/serialize, validation, and LoopBuilder for loop definitions (shared by @loop-engine/sdk and @loop-engine/registry-client).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/loop-definition"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@loop-engine/core": "workspace:*",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "files": [
    "dist/",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "homepage": "https://loopengine.io/docs/packages/sdk",
  "sideEffects": false,
  "keywords": [
    "loop-engine",
    "yaml",
    "state-machine",
    "loop-definition"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
