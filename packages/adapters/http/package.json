{
  "name": "@loop-engine/adapter-http",
  "version": "0.1.5",
  "description": "HTTP routing adapter for approval and event delivery endpoints.",
  "homepage": "https://loopengine.io/docs/packages/adapter-http",
  "keywords": [
    "loop-engine",
    "routing-adapter",
    "state-machine",
    "ai-governance",
    "human-in-the-loop",
    "http",
    "webhook",
    "delivery"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopengine/loop-engine.git",
    "directory": "packages/adapters/http"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@loop-engine/events": "workspace:*",
    "@loop-engine/runtime": "workspace:*"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
